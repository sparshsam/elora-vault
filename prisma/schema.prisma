generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionType {
  DEPOSIT
  BET_PLACED
  WIN_PROFIT
  LOSS_TO_SAVINGS
  PUSH_RETURN
  WITHDRAWAL
  LOCK_CREATED
  LOCK_RELEASED
  ONCHAIN_DEPOSIT
  ONCHAIN_LOCK_CREATED
  ONCHAIN_LOCK_RELEASED
  ONCHAIN_WITHDRAWAL
}

enum BetStatus {
  OPEN
  WON
  LOST
  PUSH
}

enum MarketType {
  MONEYLINE
  SPREAD
  TOTAL
}

enum VaultLockStatus {
  ACTIVE
  UNLOCKED
  CANCELLED
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  wallet    Wallet?
  bets      Bet[]
  transactions Transaction[]
  vaultLocks VaultLock[]
  sessions  Session[]
}

model Wallet {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])

  /// Connected Base wallet address (0x-prefixed, lowercase)
  wallet_address        String?  @unique

  user_balance          Float   @default(0)
  savings_vault         Float   @default(0)
  locked_vault_balance  Float   @default(0)
  available_vault_balance Float @default(0)
  withdrawable_winnings Float   @default(0)
  virtual_house_balance Float   @default(1000000000)
  total_deposited       Float   @default(0)
  total_wagered         Float   @default(0)
  total_saved_from_losses Float @default(0)
  total_profit_won      Float   @default(0)

  /// Capital currently committed to open bets
  at_risk_balance       Float   @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Bet {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])

  /// Human-readable description (e.g. "Leafs moneyline vs Boston")
  description   String      @default("")
  /// Sport context (optional, for categorization)
  sport         String      @default("Other")
  league        String?
  event_name    String?
  marketType    MarketType  @default(MONEYLINE)
  selection     String      @default("")
  odds          Int         @default(0)
  stake         Float       @default(0)
  potentialProfit Float     @default(0)
  potential_return Float    @default(0)
  status        BetStatus   @default(OPEN)
  settledAt     DateTime?

  /// Capital state tracking at settlement
  at_risk_before  Float?
  at_risk_after   Float?
  user_balance_before   Float?
  user_balance_after    Float?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  type          TransactionType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  betId         String?
  vaultLockId   String?         @unique
  vaultLock     VaultLock?      @relation(fields: [vaultLockId], references: [id])
  description   String

  /// Onchain transaction hash (0x-prefixed)
  tx_hash       String?

  createdAt     DateTime        @default(now())
}

model VaultLock {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Float
  createdAt   DateTime        @default(now())
  unlockAt    DateTime
  status      VaultLockStatus @default(ACTIVE)
  notes       String?

  /// Onchain lock index in the ProtectedVault contract
  onchain_lock_id  Int?
  /// Onchain transaction hash
  tx_hash          String?

  transaction Transaction?
  sessions    Session[]
}

model Session {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])

  /// Wallet address at time of session
  wallet_address String?

  /// Session metadata
  title         String?
  category      String?
  outcome       String         @default("break-even") // won | lost | break-even
  pnl           Float          @default(0)
  bankrollBefore Float         @default(0)
  bankrollAfter  Float         @default(0)
  actionTaken   String         @default("kept-available") // kept-available | protected-gains | moved-to-horizon
  notes         String?

  /// Linked horizon if gains were protected
  horizonId     String?
  horizon       VaultLock?     @relation(fields: [horizonId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
