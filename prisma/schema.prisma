generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionType {
  DEPOSIT
  BET_PLACED
  WIN_PROFIT
  LOSS_TO_SAVINGS
  PUSH_RETURN
  WITHDRAWAL
  LOCK_CREATED
  LOCK_RELEASED
  ONCHAIN_DEPOSIT
  ONCHAIN_LOCK_CREATED
  ONCHAIN_LOCK_RELEASED
  ONCHAIN_WITHDRAWAL
}

enum BetStatus {
  OPEN
  WON
  LOST
  PUSH
}

enum MarketType {
  MONEYLINE
  SPREAD
  TOTAL
}

enum VaultLockStatus {
  ACTIVE
  UNLOCKED
  CANCELLED
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  wallet    Wallet?
  bets      Bet[]
  transactions Transaction[]
  vaultLocks VaultLock[]
}

model Wallet {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])

  /// Connected Base wallet address (0x-prefixed, lowercase)
  wallet_address        String?  @unique

  user_balance          Float   @default(0)
  savings_vault         Float   @default(0)
  locked_vault_balance  Float   @default(0)
  available_vault_balance Float @default(0)
  withdrawable_winnings Float   @default(0)
  virtual_house_balance Float   @default(1000000000)
  total_deposited       Float   @default(0)
  total_wagered         Float   @default(0)
  total_saved_from_losses Float @default(0)
  total_profit_won      Float   @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Bet {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  sport         String
  league        String?
  event_name    String?
  marketType    MarketType
  selection     String
  odds          Int
  stake         Float
  potentialProfit Float
  potential_return Float
  status        BetStatus   @default(OPEN)
  settledAt     DateTime?
  house_balance_before  Float?
  house_balance_after   Float?
  user_balance_before   Float?
  user_balance_after    Float?
  savings_vault_before  Float?
  savings_vault_after   Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  type          TransactionType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  betId         String?
  vaultLockId   String?         @unique
  vaultLock     VaultLock?      @relation(fields: [vaultLockId], references: [id])
  description   String

  /// Onchain transaction hash (0x-prefixed)
  tx_hash       String?

  createdAt     DateTime        @default(now())
}

model VaultLock {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Float
  createdAt   DateTime        @default(now())
  unlockAt    DateTime
  status      VaultLockStatus @default(ACTIVE)
  notes       String?

  /// Onchain lock index in the ProtectedVault contract
  onchain_lock_id  Int?
  /// Onchain transaction hash
  tx_hash          String?

  transaction Transaction?
}
