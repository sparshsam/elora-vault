# ─── Elora Vault — Environment Variables ─────────────────
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local, .env.production, or .env.vercel.
#
# ─── Required Variables ─────────────────────────────────

# Supabase project credentials (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database connection strings (from Supabase Dashboard → Settings → Database)
# Replace YOUR-PASSWORD with the database password (not the same as Supabase auth)
DATABASE_URL="postgresql://postgres.your-project-ref:YOUR-PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR-PASSWORD@db.your-project-ref.supabase.co:5432/postgres"

# WalletConnect Project ID (required for RainbowKit)
# Get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# ─── Optional Variables ─────────────────────────────────

# Site URL (used for auth redirects)
# In production, set this to your Vercel deployment URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Base RPC URLs — optional, defaults to public endpoints
# Using a dedicated RPC provider (Alchemy, Infura, etc.) improves reliability
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# Builder Code for ERC-8021 transaction attribution (optional)
# Set to your Base Builder Code to enable onchain attribution for ecosystem
# analytics and future rewards programs. Leave empty to opt out.
# Attribution does not affect transaction execution or gas cost.
# See: https://docs.base.org/builder-codes
NEXT_PUBLIC_BASE_BUILDER_CODE=

# ─── Smart Contract Deployment ──────────────────────────
# Only needed if deploying contracts via Foundry

BASE_MAINNET_RPC_URL="https://mainnet.base.org"
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
PRIVATE_KEY="your-deployer-private-key"
BASESCAN_API_KEY="your-basescan-api-key"

# ─── Notes ──────────────────────────────────────────────
#
# · NEVER commit real values to git. This file is a template.
# · On Vercel, set env vars via the dashboard (Settings → Environment Variables).
# · The .env.production file is NOT used by Vercel; it was a local convenience
#   file that has been removed from the repository.
# · Rotate any keys that may have been exposed in git history.
