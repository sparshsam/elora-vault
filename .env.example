# ─────────────────────────────────────────────────────────
# Elora Vault — Environment Variables
# ─────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local, .env.production, or .env.vercel.
#
# Variables are grouped by purpose. Required vars MUST be set
# for the app to function. Optional vars have safe defaults.

# ─────────────────────────────────────────────────────────
# 1. REQUIRED — Supabase (Auth + Database)
# ─────────────────────────────────────────────────────────
# These come from your Supabase project dashboard:
#   Settings → API → Project URL + anon key
# Get a free Supabase project at https://supabase.com

# Public — safe in client bundles. Used for auth flows and DB queries.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — NEVER expose in client bundles.
# Used for admin-level database operations.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database connection string (via PgBouncer pooler — recommended for serverless).
# Server-only. Replace *** with your database password.
# Find it at: Settings → Database → Connection string → Pooling
DATABASE_URL="postgresql://postgres.your-project-ref:***@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct database connection (for Prisma migrations).
# Server-only. Replace *** with your database password.
DIRECT_URL="postgresql://postgres:***@db.your-project-ref.supabase.co:5432/postgres"

# ─────────────────────────────────────────────────────────
# 2. REQUIRED — WalletConnect (for RainbowKit)
# ─────────────────────────────────────────────────────────
# Get a free Project ID at https://cloud.walletconnect.com
# Public — safe in client bundles.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# ─────────────────────────────────────────────────────────
# 3. OPTIONAL — RPC Endpoints
# ─────────────────────────────────────────────────────────
# Default to public Base RPC endpoints. Using a dedicated provider
# (Alchemy, Infura, QuickNode) improves reliability and rate limits.

# Public — safe in client bundles.
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# ─────────────────────────────────────────────────────────
# 4. OPTIONAL — Site Configuration
# ─────────────────────────────────────────────────────────
# Used for auth redirects. In production, set to your deployment URL.
# Public — safe in client bundles.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────
# 5. OPTIONAL — Base Builder Code (ERC-8021 Attribution)
# ─────────────────────────────────────────────────────────
# Set to your Base Builder Code for onchain transaction attribution.
# Attribution does NOT affect execution, gas cost, or security.
# Leave empty to opt out.
# See: https://docs.base.org/builder-codes
# Public — safe in client bundles.
NEXT_PUBLIC_BASE_BUILDER_CODE=

# ─────────────────────────────────────────────────────────
# 6. CONTRACT DEPLOYMENT (Foundry — local only)
# ─────────────────────────────────────────────────────────
# Only needed if deploying contracts. NOT required for running the app.

# Server-only — NEVER commit these.
BASE_MAINNET_RPC_URL="https://mainnet.base.org"
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
PRIVATE_KEY="your-deployer-private-key"
BASESCAN_API_KEY="your-basescan-api-key"

# ─────────────────────────────────────────────────────────
# IMPORTANT NOTES
# ─────────────────────────────────────────────────────────
#
# · NEVER commit real values to git. This file is a template.
# · On Vercel, set env vars via the web dashboard:
#   Settings → Environment Variables (add all required vars)
# · The app validates required vars at startup and gives a clear
#   error message if any are missing.
# · Rotate any keys that may have been exposed in git history.
# · .env.local overrides .env in local development.
