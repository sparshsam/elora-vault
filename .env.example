# ─── Web3 / Base Network ──────────────────────────

# WalletConnect Project ID (required for RainbowKit)
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-project-id"

# Base RPC URLs (optional — defaults to public endpoints)
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# Builder Code for ERC-8021 transaction attribution (optional)
# Set to your Base Builder Code to enable onchain attribution for ecosystem
# analytics and future rewards programs. Leave empty to opt out.
# Attribution does not affect transaction execution or gas cost.
# See: https://docs.base.org/builder-codes
NEXT_PUBLIC_BASE_BUILDER_CODE=

# ─── Smart Contract Deployment ─────────────────────

# For Foundry deployment (contracts/foundry.toml)
BASE_MAINNET_RPC_URL="https://mainnet.base.org"
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
