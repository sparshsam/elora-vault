#!/usr/bin/env bash
set -euo pipefail

blocked_files='(^|/)(\.env($|\.|_)|\.env\.production$|\.env\.vercel$|vercel-env\.txt$|SECURITY_NOTES\.md$)'
blocked_patterns='(PRIVATE_KEY=|SUPABASE_SERVICE_ROLE_KEY=|DATABASE_URL=postgresql://|DIRECT_URL=postgresql://|VERCEL_OIDC_TOKEN=|ALCHEMY_RPC_URL=.*alchemy\.com/v2/|0x[0-9a-fA-F]{64}|gh[pousr]_[A-Za-z0-9_]+|sk-[A-Za-z0-9_-]+)'

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if printf '%s\n' "$staged_files" | grep -E "$blocked_files" >/dev/null; then
  echo "Blocked commit: secret-bearing environment or incident files must not be committed."
  printf '%s\n' "$staged_files" | grep -E "$blocked_files"
  exit 1
fi

if git diff --cached --unified=0 --no-ext-diff -- . ':!package-lock.json' | grep -E "$blocked_patterns" >/dev/null; then
  echo "Blocked commit: staged diff appears to contain a credential or token pattern."
  echo "Move secrets to Vercel/GitHub/Supabase secret stores and commit placeholders only."
  exit 1
fi
